rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is guide of a tour
    function isGuide(tourId) {
      return get(/databases/$(database)/documents/tours/$(tourId)).data.guideId == request.auth.uid;
    }

    // Helper: check if user has joined a tour (auto-generated ID, so query bookings)
    function hasJoinedTour(tourId) {
      return exists(/databases/$(database)/documents/bookings/$(request.auth.uid + "_" + tourId));
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Messages — only guide or tour participants can read
    match /messages/{messageId} {
      allow read: if request.auth != null && (
                    isGuide(resource.data.tourId) ||
                    hasJoinedTour(resource.data.tourId)
                  );
      allow create: if request.auth != null && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.tourId is string &&
                    request.resource.data.text is string &&
                    request.resource.data.senderName is string &&
                    request.resource.data.timestamp is timestamp;
      allow delete: if request.auth != null && 
                    resource.data.senderId == request.auth.uid;
      allow update: if false;
    }

    // Root-level bookings
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            resource.data.userId == request.auth.uid;
    }

    // Tours collection
    match /tours/{tourId} {
      allow read: if request.auth != null;
      // Admin/guide creates — guideId must match their uid
      allow create: if request.auth != null && 
                    request.resource.data.guideId == request.auth.uid;
      // Only the guide can update/delete their own tour
      allow update, delete: if request.auth != null && 
                            resource.data.guideId == request.auth.uid;

      // Bookings subcollection
      match /bookings/{bookingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && 
                              resource.data.userId == request.auth.uid;
      }
    }

    // Joined tours (auto-generated IDs)
    match /joinedTours/{joinedTourId} {
      allow read: if request.auth != null && 
                  resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            resource.data.userId == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
