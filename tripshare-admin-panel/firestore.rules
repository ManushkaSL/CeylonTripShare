rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    // This matches your app's definition - checking role field in users collection
    function isAdmin() {
      return request.auth != null && 
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
             );
    }

    // TOURS COLLECTION - PUBLIC READ (Allow everyone to browse tours)
    match /tours/{tourId} {
      allow read; // Public access - everyone can read tours
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.guideId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == resource.data.guideId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == resource.data.guideId || isAdmin());

      // Bookings subcollection
      match /bookings/{subBookingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && 
                              (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Users collection - each user has a profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // ROOT-LEVEL MESSAGES COLLECTION
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.tourId is string &&
                    request.resource.data.text is string &&
                    request.resource.data.senderName is string &&
                    request.resource.data.timestamp is timestamp;
      allow delete: if request.auth != null && 
                    (resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    // ROOT-LEVEL BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            (isAdmin() ||
                             resource.data.userId == request.auth.uid || 
                             resource.data.driverId == request.auth.uid);
    }

    // Joined tours (user booking records)
    match /joinedTours/{joinedTourId} {
      allow read: if request.auth != null && 
                           (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && 
                           request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Driver live-location sharing
    match /driver_locations/{tourId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && 
                            (request.resource.data.driverId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && 
                    (resource.data.driverId == request.auth.uid || isAdmin());
    }

    // Admin users collection (reference only)
    match /admin_users/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Drivers collection - for admin panel driver management
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Admin bypass - allow admins to read/write everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

