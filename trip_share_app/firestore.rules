rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Accept the legacy admin account, custom claims, or a role-based admin profile.
    function isAdmin() {
      return request.auth != null &&
             (
               request.auth.token.email == 'admin@gmail.com' ||
               request.auth.token.admin == true ||
               request.auth.token.role == 'admin' ||
               (
                 exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
               )
             );
    }

    // TOURS COLLECTION - PUBLIC READ (Allow everyone to browse tours)
    match /tours/{tourId} {
      allow read; // Public access - everyone can read tours
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.guideId || 
        isAdmin() ||
        (request.resource.data.keys().hasAll(['sourceIdleTourId']) && request.resource.data.sourceIdleTourId != '')
      );
      allow update: if request.auth != null; // Any authenticated user can update (for seat count during bookings)
      allow delete: if request.auth != null && isAdmin();

      // Bookings subcollection
      match /bookings/{subBookingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null;
      }
    }

    // Active booked occurrences are visible to everyone.
    match /tour_instances/{instanceId} {
      allow read;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // Users collection - each user has a profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // ROOT-LEVEL MESSAGES COLLECTION
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.tourId is string &&
                    request.resource.data.instanceId is string &&
                    request.resource.data.tourDate is string &&
                    request.resource.data.text is string &&
                    request.resource.data.senderName is string &&
                    request.resource.data.timestamp is timestamp;
      allow delete: if request.auth != null && 
                    (resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if false;
    }

    // ROOT-LEVEL BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                    request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
                    (resource.data.userId == request.auth.uid || isAdmin()) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if request.auth != null &&
                    (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Joined tours (user booking records)
    match /joinedTours/{joinedTourId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                           request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null;
    }

    // Driver live-location sharing
    match /driver_locations/{tourId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && 
                            (request.resource.data.driverId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && 
                    (resource.data.driverId == request.auth.uid || isAdmin());
    }

    // Admin users collection
    match /admin_users/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Drivers collection
    match /drivers/{driverId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && isAdmin();
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          resource.data.status == 'pending' &&
          resource.data.email == request.auth.token.email &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.status == 'active' &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.uid == request.auth.uid
        )
      );
    }

    // Admin bypass - allow admins to read/write everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

