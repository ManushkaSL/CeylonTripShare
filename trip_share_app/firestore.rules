rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admin_users/$(request.auth.email));
    }

    // Users collection - each user has a profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // ROOT-LEVEL MESSAGES COLLECTION
    // Messages from all tours in one place, filtered by tourId in queries
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.tourId is string &&
                    request.resource.data.text is string &&
                    request.resource.data.senderName is string &&
                    request.resource.data.timestamp is timestamp;
      allow delete: if request.auth != null && 
                    (resource.data.senderId == request.auth.uid || isAdmin());
      allow update: if false; // Messages cannot be edited
    }

    // ROOT-LEVEL BOOKINGS COLLECTION
    // User booking records stored at root level for efficient querying
    // (Also exists as subcollection under tours for nested queries)
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Tours collection - public read, guide & admin creates/edits
    match /tours/{tourId} {
      allow read: if true; // Publicly visible so admin pages or public catalogs can read them easily
      allow create: if request.auth != null && (request.auth.uid == request.resource.data.guideId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == resource.data.guideId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == resource.data.guideId || isAdmin());

      // Bookings subcollection
      match /bookings/{subBookingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null && 
                              (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Joined tours (user booking records)
    match /joinedTours/{joinedTourId} {
      allow read: if request.auth != null && 
                           (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && 
                           request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && 
                            (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Driver live-location sharing
    // Any authenticated user can read (passengers view driver location)
    // Only the driver themselves can write their location
    match /driver_locations/{tourId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && 
                            (request.resource.data.driverId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && 
                    (resource.data.driverId == request.auth.uid || isAdmin());
    }

    // Admin users collection - readable by web/admin panel for login verification
    match /admin_users/{document=**} {
      allow read: if true;  // Web client can read to verify admin
      allow write: if false; // Protect against client writes
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
