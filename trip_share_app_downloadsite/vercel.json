{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/.*",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/tour/.*",
      "dest": "/"
    },
    {
      "src": "/.*",
      "dest": "/"
    }
  ]
}
